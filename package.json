{
  "name": "sanctum-sdk",
  "version": "0.1.0",
  "description": "Instance-based Sanctum SDK with closed widget boundary",
  "license": "MIT",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "browser": "./dist/browser/sanctum-sdk.js",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts",
      "browser": "./dist/browser/sanctum-sdk.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:types && NODE_ENV=production rollup -c",
    "build:types": "tsc --emitDeclarationOnly --declaration --declarationDir dist/types",
    "dev": "NODE_ENV=development rollup -c --watch",
    "serve": "live-server --port=8090 --open=demo.html",
    "type-check": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@rollup/plugin-image": "^3.0.3",
    "rollup-plugin-string": "^3.0.0",
    "@rollup/plugin-replace": "^6.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "jsdom": "^26.1.0",
    "live-server": "^1.2.2",
    "rollup": "^4.24.4",
    "rollup-plugin-typescript2": "^0.36.0",
    "tslib": "^2.8.1",
    "typescript": "^5.0.0",
    "vitest": "^2.1.8"
  }
}
